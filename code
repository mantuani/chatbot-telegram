@bot.callback_query_handler(func=lambda call: call.data.startswith("adm_"))
def admin_callbacks(call):

    if call.from_user.id != ADMIN_ID:
        return

    bot.answer_callback_query(call.id)

    if call.data == "adm_stats":

        cursor.execute("SELECT COUNT(*) FROM interessados")
        total = cursor.fetchone()[0]

        cursor.execute("SELECT curso, COUNT(*) FROM interessados GROUP BY curso")
        cursos = cursor.fetchall()

        texto = f"📊 *Estatísticas*\n\n👥 Total: {total}\n\n"

        for c in cursos:
            texto += f"{c[0]}: {c[1]}\n"

        bot.send_message(call.message.chat.id, texto, parse_mode="Markdown")


    elif call.data == "adm_lista":

        cursor.execute("SELECT nome, curso, unidade FROM interessados")
        dados = cursor.fetchall()

        if not dados:
            bot.send_message(call.message.chat.id, "Nenhum interessado.")
            return

        texto = "📄 *Lista de Interessados*\n\n"

        for d in dados:
            texto += f"{d[0]} | {d[1]} | {d[2]}\n"

        bot.send_message(call.message.chat.id, texto, parse_mode="Markdown")


    elif call.data == "adm_export":

        cursor.execute("SELECT nome, curso, unidade FROM interessados")
        dados = cursor.fetchall()

        with open("interessados.csv", "w", newline="", encoding="utf-8") as f:

            writer = csv.writer(f)
            writer.writerow(["Nome", "Curso", "Unidade"])
            writer.writerows(dados)

        bot.send_document(call.message.chat.id, open("interessados.csv", "rb"))


    elif call.data == "adm_reset":

        cursor.execute("DELETE FROM interessados")
        conn.commit()

        bot.send_message(
            call.message.chat.id,
            "🗑 Banco resetado com sucesso!"
        )



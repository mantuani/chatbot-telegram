@bot.message_handler(commands=['admin'])
def admin_login(message):

    if message.from_user.id != ADMIN_ID:
        bot.reply_to(message, "🚫 Você não tem permissão.")
        return

    try:
        senha = message.text.split()[1]

    except:
        bot.reply_to(message, "❌ Use: /admin sua_senha")
        return

    if senha != ADMIN_SENHA:
        bot.reply_to(message, "❌ Senha incorreta.")
        return

    painel_admin(message.chat.id)



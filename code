# callbacks
@bot.callback_query_handler(func=lambda call: not call.data.startswith("adm_"))
def callback(call):

    bot.answer_callback_query(call.id)

    if call.data == "santa":
        cursos_menu(call, "Santa Rosália")

    elif call.data == "pagliato":
        cursos_menu(call, "Luiz Pagliato")

    elif call.data.startswith("contato|"):

        _, unidade = call.data.split("|")
        mostrar_contato(call, unidade)

    elif call.data.startswith("curso|"):

        _, unidade, curso = call.data.split("|")
        mostrar_curso(call, unidade, curso)

    elif call.data.startswith("matricula|"):

        try:

            _, unidade, curso = call.data.split("|")
            nome = call.from_user.first_name

            cursor.execute(
                "INSERT INTO interessados (nome, curso, unidade) VALUES (?, ?, ?)",
                (nome, curso, unidade)
            )

            conn.commit()

            logging.info(f"Novo interesse: {nome} - {curso} - {unidade}")

            bot.send_message(
                call.message.chat.id,
                f"🎓 {nome}, seu interesse em *{curso}* foi registrado!",
                parse_mode="Markdown"
            )

        except Exception as e:

            print(e)

            bot.send_message(
                call.message.chat.id,
                "⚠️ Ocorreu um erro ao registrar seu interesse."
            )

    elif call.data == "voltar":

        bot.delete_message(call.message.chat.id, call.message.message_id)

        menu_inicial(call.message.chat.id, call.from_user.first_name)


